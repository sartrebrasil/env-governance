# =============================================================================
# env-governance — variáveis de ambiente de exemplo
# =============================================================================
# Copie para `.env` e ajuste. Em apps Spring Boot, estas variáveis sobrescrevem
# as propriedades `env.governance.*` via relaxed binding. Em apps não-Spring,
# as VAULT_* são lidas diretamente pelo VaultEnvVarSource.
#
# Todos os valores abaixo são os DEFAULTS — só defina o que precisar mudar.
# =============================================================================

# -----------------------------------------------------------------------------
# Governança — comportamento geral
# -----------------------------------------------------------------------------
# Desliga toda a lib (útil em perfis de teste).
ENV_GOVERNANCE_ENABLED=true

# Aborta o startup se houver variáveis obrigatórias ausentes.
# Defina false em testes de integração que não precisam de todas as vars.
ENV_GOVERNANCE_FAIL_ON_MISSING=true

# Produz o relatório de diagnóstico no ApplicationReadyEvent.
ENV_GOVERNANCE_REPORT_ON_READY=true

# Inclui a seção [UNUSED] no relatório INFO.
ENV_GOVERNANCE_REPORT_ORPHAN_VARS=true

# Limita quantas variáveis não utilizadas são exibidas (evita spam).
ENV_GOVERNANCE_ORPHAN_REPORT_LIMIT=50

# -----------------------------------------------------------------------------
# Governança — contrato declarativo (validação de valor + requisitos condicionais)
# -----------------------------------------------------------------------------
# O contrato é opcional: coloque um env-governance.yml ou env-governance.properties
# no classpath. Sem arquivo, o comportamento é só de presença (idêntico ao anterior).
#
# Habilita o carregamento e a validação do contrato.
ENV_GOVERNANCE_CONTRACT_ENABLED=true

# Aborta o startup se alguma variável tiver valor inválido conforme o contrato.
# Defina false para apenas reportar as violações como [INVALID] sem falhar.
ENV_GOVERNANCE_CONTRACT_FAIL_ON_INVALID=true

# -----------------------------------------------------------------------------
# Governança — ruído de variáveis de S.O./runner na seção [UNUSED]
# -----------------------------------------------------------------------------
# Como tratar variáveis de infraestrutura (S.O., JVM, Maven, Kubernetes, CI)
# que aparecem no ambiente mas não casam com nenhuma propriedade da aplicação.
#   collapse (padrão) → colapsa em uma única linha [SYSTEM]; lista completa em DEBUG
#   hide              → remove totalmente do relatório INFO
#   full              → lista todas em [UNUSED] (comportamento legado)
ENV_GOVERNANCE_SYSTEM_VAR_MODE=collapse

# Padrões extras para classificar variáveis como infraestrutura, somados à lista
# curada embutida. Separados por vírgula. `FOO*` = prefixo, `FOO` = nome exato
# (case-insensitive). Útil para variáveis próprias do seu runner de CI.
# Exemplo:
# ENV_GOVERNANCE_SYSTEM_VAR_PATTERNS=ACME_CI_*,DEPLOY_ID

# -----------------------------------------------------------------------------
# HashiCorp Vault (apenas com env-governance-vault / -vault-starter)
# -----------------------------------------------------------------------------
# URL do servidor Vault.
# VAULT_ADDR=https://vault.example.com

# Método de autenticação: token ou approle.
# VAULT_AUTH_METHOD=token

# Auth por token.
# VAULT_TOKEN=hvs.xxxxxxxx

# Auth por AppRole (alternativa ao token).
# VAULT_ROLE_ID=
# VAULT_SECRET_ID=

# Caminhos de segredos, separados por vírgula. O primeiro tem prioridade.
# VAULT_PATHS=secret/myapp,secret/shared

# Versão do KV engine: 1 ou 2 (default: 2).
# VAULT_KV_VERSION=2

# Namespace (Vault Enterprise).
# VAULT_NAMESPACE=

# Timeout HTTP em segundos.
# VAULT_TIMEOUT_SECONDS=5

# Pula verificação de TLS — APENAS em desenvolvimento local.
# VAULT_TLS_SKIP_VERIFY=false
